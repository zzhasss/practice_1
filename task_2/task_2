#include <iostream>
#include <vector>

std::vector<std::vector<int>> g;
std::vector<bool> used;

void dfs(int v) {
    used[v] = true;

    for (int to : g[v]) {
        if (!used[to]) {
            dfs(to);
        }
    }
}

int main() {
    int N, M;
    std::cin >> N >> M;

    g.resize(N + 1);
    used.assign(N + 1, false);

    for (int i = 0; i < M; i++) {
        int u, v;
        std::cin >> u >> v;

        g[u].push_back(v);
        g[v].push_back(u);
    }

    int components = 0;

    for (int v = 1; v <= N; v++) {
        if (!used[v] && !g[v].empty()) {
            dfs(v);
            components++;
        }
    }

    std::cout << components - 1;

    return 0;
}